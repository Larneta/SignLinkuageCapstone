{
  "info": {
    "name": "SignLinkuageCapstone API",
    "description": "Runnable API collection for SignLinkuageCapstone endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "adminFirstName", "value": "System" },
    { "key": "adminLastName", "value": "Admin" },
    { "key": "adminUsername", "value": "admin@example.com" },
    { "key": "adminPassword", "value": "AdminPassword123!" },
    { "key": "userFirstName", "value": "Regular" },
    { "key": "userLastName", "value": "User" },
    { "key": "userUsername", "value": "user@example.com" },
    { "key": "userPassword", "value": "UserPassword123!" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "moduleId", "value": "1" },
    { "key": "lessonId", "value": "1" },
    { "key": "quizId", "value": "1" },
    { "key": "questionId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth - Register Admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"{{adminFirstName}}\",\n  \"lastName\": \"{{adminLastName}}\",\n  \"email\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"role\": \"ADMIN\"\n}"
        }
      }
    },
    {
      "name": "Auth - Register User",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"{{userFirstName}}\",\n  \"lastName\": \"{{userLastName}}\",\n  \"email\": \"{{userUsername}}\",\n  \"password\": \"{{userPassword}}\",\n  \"role\": \"USER\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login Admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "var data = pm.response.json();",
            "if (data.token) pm.collectionVariables.set('adminToken', data.token);"
          ]
        }
      }]
    },
    {
      "name": "Auth - Login User",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{userUsername}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "var data = pm.response.json();",
            "if (data.token) pm.collectionVariables.set('userToken', data.token);"
          ]
        }
      }]
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/auth/me"
      }
    },

    {
      "name": "Modules - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/modules",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"ASL Basics\",\n  \"description\": \"Intro module\",\n  \"orderIndex\": 1\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "var data = pm.response.json();",
            "if (data.id) pm.collectionVariables.set('moduleId', data.id);"
          ]
        }
      }]
    },
    {
      "name": "Modules - Get All",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/modules"
      }
    },
    {
      "name": "Modules - Get By Id",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/modules/{{moduleId}}"
      }
    },
    {
      "name": "Modules - Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/modules/{{moduleId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"ASL Basics Updated\",\n  \"description\": \"Updated module\",\n  \"orderIndex\": 1\n}"
        }
      }
    },

    {
      "name": "Lessons - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/lessons",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Alphabet A-F\",\n  \"description\": \"Lesson\",\n  \"moduleId\": {{moduleId}},\n  \"videoUrl\": \"https://example.com/video\",\n  \"lessonOrder\": 1,\n  \"durationSeconds\": 300\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "var data = pm.response.json();",
            "if (data.id) pm.collectionVariables.set('lessonId', data.id);"
          ]
        }
      }]
    },
    {
      "name": "Lessons - Get By Id",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/lessons/{{lessonId}}"
      }
    },
    {
      "name": "Lessons - Get By Module",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/lessons/module/{{moduleId}}"
      }
    },
    {
      "name": "Lessons - Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/lessons/{{lessonId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Alphabet A-F Updated\",\n  \"description\": \"Updated lesson\",\n  \"moduleId\": {{moduleId}},\n  \"videoUrl\": \"https://example.com/video2\",\n  \"lessonOrder\": 1,\n  \"durationSeconds\": 360\n}"
        }
      }
    },
    {
      "name": "Lessons - Mark Complete",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/lessons/{{lessonId}}/complete"
      }
    },

    {
      "name": "Quizzes - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/quizzes",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Module 1 Quiz\",\n  \"description\": \"Quiz\",\n  \"moduleId\": {{moduleId}},\n  \"passingScore\": 70,\n  \"orderIndex\": 1,\n  \"questions\": [\n    {\n      \"questionText\": \"Which sign means hello?\",\n      \"orderIndex\": 1,\n      \"answers\": [\n        {\"optionText\": \"Wave hand\", \"correct\": true, \"orderIndex\": 1},\n        {\"optionText\": \"Clap twice\", \"correct\": false, \"orderIndex\": 2}\n      ]\n    }\n  ]\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "var data = pm.response.json();",
            "if (data.id) pm.collectionVariables.set('quizId', data.id);"
          ]
        }
      }]
    },
    {
      "name": "Quizzes - Get By Id",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/quizzes/{{quizId}}"
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "var data = pm.response.json();",
            "if (data.questions && data.questions.length > 0 && data.questions[0].id) pm.collectionVariables.set('questionId', data.questions[0].id);"
          ]
        }
      }]
    },
    {
      "name": "Quizzes - Questions",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/quizzes/{{quizId}}/questions"
      }
    },
    {
      "name": "Quizzes - Answers By Question",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/quizzes/questions/{{questionId}}/answers"
      }
    },

    {
      "name": "Dashboard - Get",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/api/dashboard"
      }
    },

    {
      "name": "Admin - Create Module",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/admin/modules",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Admin Module\",\n  \"description\": \"via admin\",\n  \"orderIndex\": 99\n}"
        }
      }
    },
    {
      "name": "Admin - Create Lesson",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/admin/lessons",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Admin Lesson\",\n  \"description\": \"via admin\",\n  \"moduleId\": {{moduleId}},\n  \"videoUrl\": \"https://example.com/admin\",\n  \"lessonOrder\": 99,\n  \"durationSeconds\": 120\n}"
        }
      }
    },
    {
      "name": "Admin - Create Quiz",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/admin/quizzes",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Admin Quiz\",\n  \"description\": \"via admin\",\n  \"moduleId\": {{moduleId}},\n  \"passingScore\": 70,\n  \"orderIndex\": 100,\n  \"questions\": [\n    {\n      \"questionText\": \"Sample?\",\n      \"orderIndex\": 1,\n      \"answers\": [\n        {\"optionText\": \"Yes\", \"correct\": true, \"orderIndex\": 1},\n        {\"optionText\": \"No\", \"correct\": false, \"orderIndex\": 2}\n      ]\n    }\n  ]\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "var data = pm.response.json();",
            "if (data.id) pm.collectionVariables.set('quizId', data.id);"
          ]
        }
      }]
    },

    {
      "name": "Cleanup - Delete Quiz",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/quizzes/{{quizId}}"
      }
    },
    {
      "name": "Cleanup - Delete Lesson",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/lessons/{{lessonId}}"
      }
    },
    {
      "name": "Cleanup - Delete Module",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/modules/{{moduleId}}"
      }
    }
  ]
}